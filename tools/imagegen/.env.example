# Copy to .env and fill in the key for whichever provider you use.
# .env is gitignored. Never commit real keys.

# Google AI Studio key (for --provider gemini): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI key (for --provider openai): https://platform.openai.com/api-keys
OPENAI_API_KEY=
